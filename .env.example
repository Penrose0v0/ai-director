# Copy to .env.local and fill in when you have access.
# Server-side only — do NOT prefix with NEXT_PUBLIC (keeps the key out of the browser).
# Restart `npm run dev` after editing.

GEMINI_API_KEY=
# Optional model overrides (sensible defaults are used if unset).
GEMINI_MODEL=gemini-2.5-flash
# Image model for storyboard frames (Imagen). Falls back to an SVG placeholder on error.
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# Video model (Veo). Falls back to the bundled sample video on error.
GEMINI_VIDEO_MODEL=veo-3.0-generate-001
